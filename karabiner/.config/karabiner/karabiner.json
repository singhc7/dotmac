{
    "profiles": [
        {
            "name": "Default profile",
            "selected": false,
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "ansi"
            }
        },
        {
            "name": "chahat",
            "selected": true,
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "ansi"
            },
            "complex_modifications": {
                "parameters": {
                    "basic.to_if_alone_timeout_milliseconds": 200,
                    "basic.simultaneous_threshold_milliseconds": 80,
                    "basic.to_if_held_down_threshold_milliseconds": 350
                },
                "rules": [
                    {
                        "description": "[Hyper] Caps Lock → Escape (tap) / Hyper ⇧⌃⌥⌘ (hold). Frees Caps for a dedicated power-user modifier; Esc when tapped alone keeps vim/readline happy.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": [
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }]
                            }
                        ]
                    },
                    {
                        "description": "[Nav] Hyper + hjkl → ← ↓ ↑ →. Vim-style arrows everywhere (Finder, browsers, GUI apps that ignore terminal vim modes).",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "h",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "left_arrow" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "j",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "down_arrow" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "k",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "up_arrow" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "l",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "right_arrow" }]
                            }
                        ]
                    },
                    {
                        "description": "[Nav] Hyper + u/i/o/p → Home / PageDown / PageUp / End. Long-distance nav without reaching for the arrow cluster.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "u",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "home" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "i",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "page_down" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "o",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "page_up" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "p",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "end" }]
                            }
                        ]
                    },
                    {
                        "description": "[Edit] Hyper + ⌫ → Forward delete. MacBooks lack a real Del key.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "delete_or_backspace",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "key_code": "delete_forward" }]
                            }
                        ]
                    },
                    {
                        "description": "[Media] Hyper + , / . / / → Volume Down / Up / Mute. Keeps the top function row free.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "comma",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "consumer_key_code": "volume_decrement" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "period",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "consumer_key_code": "volume_increment" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "slash",
                                    "modifiers": {
                                        "mandatory": [
                                            "left_shift",
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                },
                                "to": [{ "consumer_key_code": "mute" }]
                            }
                        ]
                    },
                    {
                        "description": "[Mod] Right ⌘ → Return (tap) / ⌘ (hold). One-handed enter without leaving the home row.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "right_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "key_code": "right_command", "lazy": true }
                                ],
                                "to_if_alone": [
                                    { "key_code": "return_or_enter" }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "[Mod] Left ⇧ + Right ⇧ → Caps Lock toggle. Reclaims the lost Caps Lock for the rare moment you actually want it.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "simultaneous": [
                                        { "key_code": "left_shift" },
                                        { "key_code": "right_shift" }
                                    ],
                                    "modifiers": { "optional": ["caps_lock"] }
                                },
                                "to": [{ "key_code": "caps_lock" }]
                            }
                        ]
                    },
                    {
                        "description": "[Safety] Hold ⌘Q to quit (350ms). A quick ⌘Q is swallowed so a slipped finger near ⌘W never nukes your work.",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "q",
                                    "modifiers": {
                                        "mandatory": ["left_command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to_if_held_down": [
                                    {
                                        "key_code": "q",
                                        "modifiers": ["left_command"]
                                    }
                                ],
                                "parameters": {
                                    "basic.to_if_held_down_threshold_milliseconds": 350
                                }
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
